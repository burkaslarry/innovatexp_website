# Copy to .env.local / Vercel project env (never commit secrets).

# Resend — questionnaire notification email
RESEND_API_KEY=
# Verified sender, e.g. InnovateXP <noreply@innovatexp.co> or onboarding@resend.dev for testing
RESEND_FROM_EMAIL=InnovateXP <onboarding@resend.dev>
# Inbox that receives questionnaire leads
QUESTIONNAIRE_NOTIFY_EMAIL=info@innovatexp.co

# Notion — questionnaire CRM database (same NOTION_TOKEN as calendar)
# NOTION_TOKEN=
NOTION_QUESTIONNAIRE_DB_ID=

# Recommended Notion DB properties:
# Name (title), Company, Profession, Email, Phone, Type (select), Status (select),
# Industry, Urgency, Interest, Answers (rich_text)
